{
  "docker": {
    "file": "Dockerfile",
    "context": ".",
    "target": {
      "registry": "",
      "repository": ""
    },
    "login": {
      "registry": ""
    },
    "push": {
      "enabled": false,
      "branches": []
    },
    "tags": {
      "latest": false
    },
    "platform": "",
    "buildArgs": {}
  },

  "version": {
    "provider": "auto",

    "nbgv": {
      "versionJsonFileName": "version.json",
      "dotnetToolManifestRelativePath": ".config/dotnet-tools.json",
      "useDocker": true,
      "dockerImage": "mcr.microsoft.com/dotnet/sdk:latest",
      "allowToolRestore": true,
      "allowGlobalCommand": true,
      "requireVersionJson": true
    },

    "nodejs": {
      "packageJsonPath": "package.json",
      "mode": "git-height"
    },

    "dotnet": {
      "mode": "git-height",
      "mainAssemblyInfoFilePath": "",
      "assemblyInfoFilePaths": [],
      "versionInfoFilePaths": [],
      "csprojFilePaths": [],
      "autoDiscover": true
    }
  }
}
