{
  "name": "@agile-north/dockship",
  "version": "1.3.0",
  "description": "Docker container versioning, building, and publishing CLI for opinionated CI/CD",
  "private": false,
  "type": "commonjs",
  "bin": {
    "dock": "cli.cjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./cli.cjs build",
    "ship": "node ./cli.cjs push",
    "all": "node ./cli.cjs all",
    "version": "node ./cli.cjs version",
    "tags": "node ./cli.cjs tags",
    "test": "node --test"
  },
  "files": [
    "cli.cjs",
    "build.cjs",
    "lib"
  ],
  "keywords": [
    "docker",
    "ci",
    "cd",
    "version",
    "semver",
    "build",
    "publish"
  ],
  "author": "NRTH",
  "homepage": "https://www.nrth.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agile-north/dockship.git"
  },
  "bugs": {
    "url": "https://github.com/agile-north/dockship/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}